---
import { siteConfig } from "../config";
import chubbImage from "../img/Chubb.jpg";
import instahubImage from "../img/instahub.jpeg";
import finbudImage from "../img/finbud.jpg";
import manipalImage from "../img/MANIPAL-INSTITUTE-OF-TECHNOLOGY.jpg";
import njitImage from "../img/njit.png";
import bioImage from "../img/bio.jpg";
const hasExperience = siteConfig.experience && siteConfig.experience.length > 0;

const experienceImages = {
  Chubb: chubbImage.src,
  InstaHub: instahubImage.src,
  FinBud: finbudImage.src,
  "Manipal Institute of Technology": manipalImage.src,
  "Computational Neuroanatomy and Neuroinformatics Lab, NJIT": njitImage.src,
};

const defaultExperienceImage = bioImage.src;
---

{
  hasExperience && (
    <section id="experience" class="section py-24 px-5">
      <div class="max-w-6xl mx-auto">
        <div class="section-title">
          <h2>Experience</h2>
        </div>

        <div class="timeline">
          {siteConfig.experience.map((exp, index) => (
            <div
              class={`timeline-item ${index % 2 === 0 ? "left" : "right"}`}
            >
              <div class="timeline-content">
                <img
                  src={experienceImages[exp.company] ?? defaultExperienceImage}
                  alt={`${exp.company} image`}
                  class={`timeline-card-image ${exp.company === "FinBud" ? "timeline-card-image-finbud" : ""}`}
                />
                <div class="timeline-card-text">
                  <h3>{exp.company}</h3>
                  <h4>{exp.title}</h4>
                  <p class="date">{exp.dateRange}</p>
                </div>
                <ul>
                  {exp.bullets.map((bullet) => (
                    <li>{bullet}</li>
                  ))}
                </ul>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>
  )
}

<style>
  .timeline-card-image {
    width: 100%;
    height: 170px;
    border-radius: 12px;
    object-fit: cover;
    object-position: center;
    background: rgba(255, 255, 255, 0.92);
    border: 1px solid rgba(255, 255, 255, 0.2);
    margin-bottom: 12px;
    display: block;
  }

  .timeline-card-text {
    min-width: 0;
    margin-bottom: 6px;
  }

  .timeline-card-image-finbud {
    height: 140px;
    object-fit: contain;
    background: rgba(255, 255, 255, 0.98);
    padding: 6px;
  }

  @media (max-width: 768px) {
    .timeline-card-image {
      height: 150px;
    }

    .timeline-card-image-finbud {
      height: 130px;
    }
  }
</style>
