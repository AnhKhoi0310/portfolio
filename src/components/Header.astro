---
import { siteConfig } from "../config";

const hasProjects = siteConfig.projects && siteConfig.projects.length > 0;
const hasExperience = siteConfig.experience && siteConfig.experience.length > 0;
const hasEducation = siteConfig.education && siteConfig.education.length > 0;
const hasSkills =
  siteConfig.skillCategories && siteConfig.skillCategories.length > 0;

const [firstName, ...rest] = siteConfig.name.split(" ");
const lastName = rest.join(" ");
---

<header
  id="header"
  class="fixed top-0 left-0 right-0 z-50 transition-all duration-300 py-5"
  style="background-color: rgba(10, 25, 47, 0.9);"
>
  <div class="max-w-6xl mx-auto px-5 flex items-center justify-between gap-4">
    <a href="#hero" class="text-xl md:text-2xl font-bold text-white no-underline shrink-0">
      {firstName}
      <span style={`color: ${siteConfig.accentColor}`}>{lastName}</span>
    </a>

    <nav id="main-nav" class="main-nav hidden md:block">
      <ul class="flex items-center gap-6 list-none m-0 p-0">
        <li><a href="#about" class="nav-link">About</a></li>
        {
          hasEducation && (
            <li>
              <a href="#education" class="nav-link">Education</a>
            </li>
          )
        }
        {
          hasExperience && (
            <li>
              <a href="#experience" class="nav-link">Experience</a>
            </li>
          )
        }
        {
          hasProjects && (
            <li>
              <a href="#projects" class="nav-link">Projects</a>
            </li>
          )
        }
        {
          hasSkills && (
            <li>
              <a href="#skills" class="nav-link">Skills</a>
            </li>
          )
        }
        <li><a href="#contact" class="nav-link">Contact</a></li>
      </ul>
    </nav>

    <div class="hidden md:flex items-center gap-4">
      {
        siteConfig.social?.email && (
          <a
            href={`mailto:${siteConfig.social.email}`}
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Email"
            class="social-icon"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path stroke="none" d="M0 0h24v24H0z" fill="none"/><path d="M3 7a2 2 0 0 1 2 -2h14a2 2 0 0 1 2 2v10a2 2 0 0 1 -2 2h-14a2 2 0 0 1 -2 -2v-10z"/><path d="M3 7l9 6l9 -6"/></svg>
          </a>
        )
      }
      {
        siteConfig.social?.linkedin && (
          <a
            href={siteConfig.social.linkedin}
            target="_blank"
            rel="noopener noreferrer"
            aria-label="LinkedIn"
            class="social-icon"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path stroke="none" d="M0 0h24v24H0z" fill="none"/><path d="M8 11v5"/><path d="M8 8v.01"/><path d="M12 16v-5"/><path d="M16 16v-3a2 2 0 1 0 -4 0"/><path d="M3 7a4 4 0 0 1 4 -4h10a4 4 0 0 1 4 4v10a4 4 0 0 1 -4 4h-10a4 4 0 0 1 -4 -4z"/></svg>
          </a>
        )
      }
      {
        siteConfig.social?.github && (
          <a
            href={siteConfig.social.github}
            target="_blank"
            rel="noopener noreferrer"
            aria-label="GitHub"
            class="social-icon"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path stroke="none" d="M0 0h24v24H0z" fill="none"/><path d="M9 19c-4.3 1.4 -4.3 -2.5 -6 -3m12 5v-3.5c0 -1 .1 -1.4 -.5 -2c2.8 -.3 5.5 -1.4 5.5 -6a4.6 4.6 0 0 0 -1.3 -3.2a4.2 4.2 0 0 0 -.1 -3.2s-1.1 -.3 -3.5 1.3a12.3 12.3 0 0 0 -6.2 0c-2.4 -1.6 -3.5 -1.3 -3.5 -1.3a4.2 4.2 0 0 0 -.1 3.2a4.6 4.6 0 0 0 -1.3 3.2c0 4.6 2.7 5.7 5.5 6c-.6 .6 -.6 1.2 -.5 2v3.5"/></svg>
          </a>
        )
      }
      {
        siteConfig.social?.leetcode && (
          <a
            href={siteConfig.social.leetcode}
            target="_blank"
            rel="noopener noreferrer"
            aria-label="LeetCode"
            class="social-icon social-icon-text"
          >
            LC
          </a>
        )
      }
    </div>

    <button
      id="mobile-nav-toggle"
      class="md:hidden bg-transparent border-none cursor-pointer p-2"
      aria-label="Toggle navigation"
    >
      <span class="hamburger"></span>
    </button>
  </div>

  <nav id="mobile-nav" class="md:hidden mobile-nav-panel">
    <ul class="flex flex-col gap-4 list-none m-0 p-5">
      <li><a href="#about" class="nav-link mobile-nav-link">About</a></li>
      {
        hasEducation && (
          <li>
            <a href="#education" class="nav-link mobile-nav-link">Education</a>
          </li>
        )
      }
      {
        hasExperience && (
          <li>
            <a href="#experience" class="nav-link mobile-nav-link">Experience</a>
          </li>
        )
      }
      {
        hasProjects && (
          <li>
            <a href="#projects" class="nav-link mobile-nav-link">Projects</a>
          </li>
        )
      }
      {
        hasSkills && (
          <li>
            <a href="#skills" class="nav-link mobile-nav-link">Skills</a>
          </li>
        )
      }
      <li><a href="#contact" class="nav-link mobile-nav-link">Contact</a></li>
    </ul>
  </nav>
</header>

<script>
  const header = document.getElementById("header");
  const mobileToggle = document.getElementById("mobile-nav-toggle");
  const mobileNav = document.getElementById("mobile-nav");

  window.addEventListener("scroll", () => {
    if (window.scrollY > 50) {
      header?.classList.add("scrolled");
    } else {
      header?.classList.remove("scrolled");
    }
  });

  mobileToggle?.addEventListener("click", () => {
    mobileNav?.classList.toggle("active");
    mobileToggle.classList.toggle("active");
  });

  document.querySelectorAll(".mobile-nav-link").forEach((link) => {
    link.addEventListener("click", () => {
      mobileNav?.classList.remove("active");
      mobileToggle?.classList.remove("active");
    });
  });
</script>

<style>
  .nav-link {
    color: white;
    text-decoration: none;
    font-weight: 500;
    font-size: 1rem;
    padding: 0.5rem 0;
    position: relative;
    transition: color 0.3s ease;
  }

  .nav-link:hover {
    color: var(--primary-color);
  }

  .nav-link::after {
    content: "";
    position: absolute;
    bottom: 0;
    left: 0;
    width: 0;
    height: 2px;
    background: var(--primary-color);
    transition: width 0.3s ease;
  }

  .nav-link:hover::after {
    width: 100%;
  }

  .social-icon {
    color: white;
    transition: all 0.3s ease;
  }

  .social-icon-text {
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.02em;
    text-decoration: none;
  }

  .social-icon:hover {
    color: var(--primary-color);
    transform: translateY(-3px);
  }

  #header.scrolled {
    padding-top: 0.625rem;
    padding-bottom: 0.625rem;
    box-shadow: 0 5px 20px rgba(0, 0, 0, 0.2);
  }

  .hamburger {
    display: block;
    width: 1.5rem;
    height: 2px;
    background: white;
    position: relative;
  }

  .hamburger::before,
  .hamburger::after {
    content: "";
    position: absolute;
    width: 1.5rem;
    height: 2px;
    background: white;
    left: 0;
    transition: all 0.3s ease;
  }

  .hamburger::before {
    top: -6px;
  }

  .hamburger::after {
    bottom: -6px;
  }

  .mobile-nav-panel {
    background: rgba(10, 25, 47, 0.98);
    transform: translateY(-150%);
    transition: transform 0.3s ease;
    position: absolute;
    top: 100%;
    left: 0;
    right: 0;
  }

  .mobile-nav-panel.active {
    transform: translateY(0);
  }
</style>
