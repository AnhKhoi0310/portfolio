---
import { siteConfig } from "../config";
import cpaImage from "../img/cpa-rag-agent.jpeg";
import smartAgriImage from "../img/bio.jpg";
import chartMakerImage from "../img/chart-maker.png";
import defaultProfileImage from "../img/1.jpg";
const hasProjects = siteConfig.projects && siteConfig.projects.length > 0;

const projectImages = {
  "CPA Agent Bot": cpaImage.src,
  "Graph Theoretical Analysis of Task-related Functional Dynamics (GAT-FD)": smartAgriImage.src,
  "LLM-powered ChartMaker": chartMakerImage.src,
};

const defaultProjectImage = defaultProfileImage.src;
---

{
  hasProjects && (
    <section id="projects" class="section py-24 px-5">
      <div class="max-w-6xl mx-auto">
        <div class="section-title">
          <h2>Projects</h2>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
          {siteConfig.projects.map((project) => (
            <div class="project-card group">
              <img
                src={projectImages[project.name] ?? defaultProjectImage}
                alt={project.name}
                class="project-banner"
              />
              <div class="p-6">
                <h3
                  class="text-xl font-semibold mb-3"
                  style={`color: ${siteConfig.accentColor}`}
                >
                  {project.name}
                </h3>
                <p class="text-white/75 text-sm leading-relaxed mb-4">
                  {project.description}
                </p>
                {project.skills && project.skills.length > 0 && (
                  <div class="mb-4">
                    {project.skills.map((skill) => (
                      <span class="tech-tag">{skill}</span>
                    ))}
                  </div>
                )}
                {project.link && (
                  <div class="flex gap-4">
                    <a
                      href={project.link}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="project-link"
                    >
                      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 19c-4.3 1.4 -4.3 -2.5 -6 -3m12 5v-3.5c0 -1 .1 -1.4 -.5 -2c2.8 -.3 5.5 -1.4 5.5 -6a4.6 4.6 0 0 0 -1.3 -3.2a4.2 4.2 0 0 0 -.1 -3.2s-1.1 -.3 -3.5 1.3a12.3 12.3 0 0 0 -6.2 0c-2.4 -1.6 -3.5 -1.3 -3.5 -1.3a4.2 4.2 0 0 0 -.1 3.2a4.6 4.6 0 0 0 -1.3 3.2c0 4.6 2.7 5.7 5.5 6c-.6 .6 -.6 1.2 -.5 2v3.5"/></svg>
                      Code
                    </a>
                  </div>
                )}
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>
  )
}

<style>
  .project-card {
    background: rgba(255, 255, 255, 0.05);
    border-radius: 10px;
    overflow: hidden;
    transition: all 0.3s ease;
    box-shadow: 0 5px 15px rgba(0, 0, 0, 0.1);
    border: 1px solid rgba(255, 255, 255, 0.05);
  }

  .project-banner {
    width: 100%;
    height: 190px;
    object-fit: cover;
    object-position: center;
    border-radius: 10px 10px 0 0;
    background: rgba(255, 255, 255, 0.92);
    display: block;
    border-bottom: 1px solid rgba(255, 255, 255, 0.12);
  }

  .project-card:hover {
    transform: translateY(-10px);
    box-shadow: 0 15px 30px rgba(0, 0, 0, 0.25);
    border-color: rgba(51, 238, 244, 0.2);
  }

  .project-link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    color: white;
    text-decoration: none;
    font-size: 0.9rem;
    transition: color 0.3s ease;
  }

  .project-link:hover {
    color: var(--primary-color);
  }

  @media (max-width: 768px) {
    .project-banner {
      height: 165px;
    }
  }
</style>
