---
import { siteConfig } from "../config";
import profileImage1 from "../img/1.jpg";

const paragraphs = siteConfig.aboutMe.split("\n\n").filter(Boolean);
---

<section id="about" class="section py-24 px-5" style="background: rgba(10, 25, 47, 0.95);">
  <div class="max-w-6xl mx-auto">
    <div class="section-title">
      <h2>About Me</h2>
    </div>

    <div class="flex flex-col md:flex-row items-center gap-10 md:gap-16">
      <div class="flex-1 min-w-[280px] flex justify-center">
        <div
          class="w-full max-w-sm aspect-square rounded-xl relative overflow-hidden flex items-center justify-center text-7xl font-bold shadow-xl border border-white/10"
          style={`background-image: url(${profileImage1.src}); background-size: cover; background-position: center; color: ${siteConfig.accentColor};`}
        >
        </div>
      </div>

      <div class="flex-1 min-w-[280px]">
        {
          paragraphs.map((paragraph) => (
            <p class="text-base md:text-lg leading-relaxed text-white/80 mb-5">
              {paragraph}
            </p>
          ))
        }
        <a href="#education" class="btn-primary mt-2">View My Education</a>
      </div>
    </div>
  </div>
</section>

